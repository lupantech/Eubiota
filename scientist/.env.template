# Scientist Environment Configuration Template
# Copy this file to .env and fill in your API keys

# ========================================
# LLM Provider API Keys
# ========================================

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Google API Key (for Gemini models)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key (for Claude models, optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# Alibaba Dashscope (for Qwen models, optional)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Together AI (optional)
TOGETHER_API_KEY=your_together_api_key_here

# DeepSeek (optional)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# xAI (Grok, optional)
XAI_API_KEY=your_xai_api_key_here

# ========================================
# Tool-specific API Keys
# ========================================

# Google Custom Search (for Google Search Tool, optional)
GOOGLE_API_KEY=your_google_api_key_here  # Can reuse the Gemini key or use a separate one

# Perplexity API (for Perplexity Search Tool)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# PubMed/NCBI (optional, increases rate limits)
NCBI_API_KEY=your_ncbi_api_key_here
ENTREZ_EMAIL=your_email@example.com

# ========================================
# Optional Settings
# ========================================

# Cache directory (optional, defaults to system cache)
# CACHE_DIR=/path/to/cache/directory

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Workspace directory for tool execution
WORKSPACE_PATH=./workspace
